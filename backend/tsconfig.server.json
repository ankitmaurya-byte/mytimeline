{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "ES2020",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": false,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ]
        }
    },
    "include": [
        "src/server.ts",
        "src/services/**/*.ts",
        "src/api-lib/**/*.ts",
        "src/models/**/*.ts",
        "src/utils/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        ".next"
    ]
}



