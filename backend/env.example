# Timeline Backend Environment Configuration
# Copy this file to .env.local for development or .env.production for production

# Node Environment
NODE_ENV=development
PORT=8000

# Database Configuration
MONGO_URI=mongodb://localhost:27017/timelineDB
# For production with MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/timelineDB?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-characters-long
JWT_REFRESH_EXPIRES_IN=30d

# Session & Security
SESSION_SECRET=your-super-secret-session-key-at-least-32-characters-long
SESSION_EXPIRES_IN=7d
COOKIE_SECRET=your-super-secret-cookie-key-at-least-32-characters-long
BCRYPT_SALT_ROUNDS=12

# OAuth - Google (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# OAuth - GitHub (Optional)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/oauth/github/callback

# Redis (Optional - for caching and sessions)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Email Configuration (Optional)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Timeline Team

# Application URLs
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin Bootstrap (Optional)
ADMIN_EMAIL=admin@timeline.com
ADMIN_PASSWORD=admin123456

# Logging
LOG_LEVEL=info

# AI Services (Optional)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Monitoring (Optional)
SENTRY_DSN=your-sentry-dsn
ANALYTICS_API_KEY=your-analytics-key

