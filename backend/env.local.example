# ═══════════════════════════════════════════════════════════
#  Timeline Backend — Environment Variables
#  HOW TO USE:
#    cp env.local.example .env.local
#  Then replace every value marked  ← REPLACE
# ═══════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=8000
WS_PORT=8001
HOSTNAME=0.0.0.0

# ── Database ─────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers    ← REPLACE
MONGO_URI=mongodb+srv://devuser:devpassword@cluster0.abcde.mongodb.net/timelineDB?retryWrites=true&w=majority

# ── JWT & Session Secrets ────────────────────────────────
# Must be ≥ 32 chars. Generate with: openssl rand -hex 32   ← REPLACE
JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
JWT_REFRESH_EXPIRES_IN=30d
SESSION_SECRET=zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz
SESSION_EXPIRES_IN=7d
COOKIE_SECRET=wwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwww
BCRYPT_SALT_ROUNDS=12

# ── OAuth — Google ───────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials  ← REPLACE
GOOGLE_CLIENT_ID=000000000000-abcdefghijklmnopqrstuvwxyz123456.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-ReplaceWithRealGoogleSecret123456
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# ── OAuth — GitHub ───────────────────────────────────────
# Get from: https://github.com/settings/developers           ← REPLACE
GITHUB_CLIENT_ID=Iv1.ReplaceWithRealGithubId
GITHUB_CLIENT_SECRET=ReplaceWithRealGithubSecret0123456789abcdef
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/oauth/github/callback

# ── Redis (optional) ─────────────────────────────────────
# Leave blank to disable Redis caching
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Email / SMTP ─────────────────────────────────────────
# Gmail: enable 2FA → App Passwords → generate one          ← REPLACE
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=youremail@gmail.com
EMAIL_SMTP_PASS=xxxx_your_gmail_app_password_xxxx
EMAIL_FROM=youremail@gmail.com
EMAIL_FROM_NAME=Timeline Team

# ── Application URLs ─────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ORIGIN=http://localhost:3000
# For multiple origins (comma-separated):
# CORS_ADDITIONAL_ORIGINS=https://staging.yourapp.com,https://yourapp.com

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Admin Bootstrap ──────────────────────────────────────
# Used once to seed first admin account                      ← REPLACE
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=ChangeMe_AdminPass123!

# ── Logging ──────────────────────────────────────────────
# Options: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── AI Services (optional) ───────────────────────────────
# Get from: https://platform.openai.com/api-keys            ← REPLACE
OPENAI_API_KEY=sk-proj-ReplaceWithRealOpenAIKey0000000000000000000000000
# Get from: https://console.anthropic.com/                  ← REPLACE
ANTHROPIC_API_KEY=sk-ant-api03-ReplaceWithRealAnthropicKey00000000000000000000000000

# ── Cloudinary (profile picture uploads) ─────────────────
# Get from: https://cloudinary.com/console                  ← REPLACE
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=111111111111111
CLOUDINARY_API_SECRET=ReplaceWithRealCloudinaryApiSecret

# ── File Upload ──────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# ── Monitoring (optional) ────────────────────────────────
# Get from: https://sentry.io/settings/projects/            ← REPLACE
SENTRY_DSN=https://ReplaceKey@o000000.ingest.sentry.io/0000000
ANALYTICS_API_KEY=ReplaceWithRealAnalyticsKey
