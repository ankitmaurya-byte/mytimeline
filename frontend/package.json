{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "vercel": "vercel",
    "analyze": "ANALYZE=true npm run build",
    "analyze:bundle": "node scripts/analyze-bundle.mjs",
    "optimize": "node scripts/optimize-performance.mjs",
    "optimize:aggressive": "node scripts/aggressive-optimization.mjs",
    "replace:emoji-picker": "node scripts/replace-emoji-picker.mjs",
    "build:analyze": "npm run build && npm run analyze",
    "build:optimize": "npm run build && npm run analyze:bundle",
    "build:aggressive": "npm run build && npm run optimize:aggressive",
    "build:no-emoji-mart": "npm run replace:emoji-picker && npm run build"
  },
