# frontend/.env.example
# Backend API Configuration
NEXT_PUBLIC_BACKEND_URL=your_backend_url_here

# Authentication Configuration
NEXT_PUBLIC_AUTH_COOKIE_NAME=auth_active
NEXT_PUBLIC_AUTH_TOKEN_COOKIE_NAME=auth_token

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Cloudinary Configuration
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here

# Redis Configuration
NEXT_PUBLIC_REDIS_HOST=localhost
NEXT_PUBLIC_REDIS_PORT=6379
NEXT_PUBLIC_REDIS_PASSWORD=
NEXT_PUBLIC_REDIS_DB=0

# Logging Configuration
NEXT_PUBLIC_LOG_LEVEL=info

# Microsoft Clarity Analytics
NEXT_PUBLIC_CLARITY_PROJECT_ID=u06yk9g7bb

