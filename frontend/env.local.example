# ═══════════════════════════════════════════════════════════
#  Timeline Frontend — Environment Variables
#  HOW TO USE:
#    cp env.local.example .env.local
#  Then replace every value marked  ← REPLACE
# ═══════════════════════════════════════════════════════════

# ── Backend API URL ──────────────────────────────────────
# Local dev: http://localhost:8000
# Production: https://your-backend.herokuapp.com           ← REPLACE
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── Auth Cookie Names ────────────────────────────────────
# Must match what backend sets (auth_token / auth_active)
NEXT_PUBLIC_AUTH_COOKIE_NAME=auth_active
NEXT_PUBLIC_AUTH_TOKEN_COOKIE_NAME=auth_token

# ── Cloudinary (for avatar display) ─────────────────────
# Get from: https://cloudinary.com/console                 ← REPLACE
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ── Microsoft Clarity (analytics, optional) ──────────────
# Get from: https://clarity.microsoft.com/                 ← REPLACE
NEXT_PUBLIC_CLARITY_PROJECT_ID=ReplaceWithRealClarityProjectId

# ── Logging ──────────────────────────────────────────────
# Options: debug | info | warn | error
NEXT_PUBLIC_LOG_LEVEL=info

# ── WebSocket URL ────────────────────────────────────────
# Used by use-websocket-online-status.ts
# Local: ws://localhost:8000/ws   Production: wss://your-backend.com/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ── Feature Flags (optional) ─────────────────────────────
NEXT_PUBLIC_ENABLE_AI_CHAT=true
NEXT_PUBLIC_ENABLE_BIOMETRIC=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
